<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:padding="@dimen/padding_medium">
    <!--  Game card item holds the title of game and image  -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/game_image_holder"
        android:layout_width="@dimen/game_image_width"
        android:layout_height="@dimen/game_image_height"
        android:contentDescription="@null"
        android:elevation="@dimen/game_image_elevation"
        android:scaleType="fitXY"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.CornerSize4DP" />

    <TextView
        android:id="@+id/textview_game_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/padding_small"
        android:gravity="center"
        android:textAppearance="@style/TextAppearance.MaterialComponents.Body1"
        app:layout_constraintEnd_toEndOf="@id/game_image_holder"
        app:layout_constraintStart_toStartOf="@id/game_image_holder"
        app:layout_constraintTop_toBottomOf="@id/game_image_holder"
        tools:text="Game title name" />


</androidx.constraintlayout.widget.ConstraintLayout>